# Copy to .env and fill values.

# Trails widget API key (Fund onramp widget).
VITE_TRAILS_API_KEY=

# Sequence indexer access key — used to show the USD balance in the dashboard.
VITE_INDEXER_ACCESS_KEY=

# Fallback used as the indexer access key if VITE_INDEXER_ACCESS_KEY is unset.
VITE_PROJECT_ACCESS_KEY=

# oidc-relay base URL for the /login pairing session.
VITE_OIDC_RELAY_URL=https://oidc-relay.polygon.technology
