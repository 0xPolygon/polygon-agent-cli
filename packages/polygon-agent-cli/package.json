{
  "name": "@polygonlabs/agent-cli",
  "version": "0.10.4",
  "description": "CLI + Agent Skills for building on-chain agents on Polygon",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xPolygon/polygon-agent-cli",
    "directory": "packages/polygon-agent-cli"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "polygon-agent": "dist/index.js"
  },
  "files": [
    "dist",
    "contracts"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepublishOnly": "pnpm run build",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@0xsequence/network": "^2.3.40",
    "@0xsequence/typescript-sdk": "0.1.0-alpha.4",
    "@0xtrails/api": "^0.10.4",
    "@polymarket/clob-client-v2": "^1.0.0",
    "@polymarket/sdk": "^6.0.1",
    "@x402/core": "^2.3.1",
    "@x402/evm": "^2.3.1",
    "@x402/fetch": "^2.3.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "ethers5": "npm:ethers@^5.7.4",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "viem": "^2.45.3",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/yargs": "^17.0.33",
    "esbuild": "^0.28.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
